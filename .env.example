# ─────────────────────────────────────────────
#  RAG Chat — Environment Variables
#  Copy this file to .env.local and fill in values
# ─────────────────────────────────────────────

# Login credentials (change before deploying!)
LOGIN_USERNAME=admin
LOGIN_PASSWORD=admin123

# Session secret — use a long random string in production
SESSION_SECRET=change-me-to-a-long-random-string

# LLM provider: "anthropic" | "openai"
# (Can also be set from the Settings page inside the app)
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6

# API key for your LLM provider
# (Can also be set from the Settings page inside the app)
LLM_API_KEY=sk-ant-api03-...

# RAG parameters (optional — defaults shown)
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K=3
