# ─────────────────────────────────────────────────────────────────────────────
#  CogniBase — Environment Variables
#  Copy to .env.local (dev) or .env (production) and fill in values.
#  NEVER commit your real .env file — it is in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Auth & Session ────────────────────────────────────────────────────────────
# Used to seed the first admin account on a blank database.
# Once you log in you can create additional users via Admin Panel → Users.
LOGIN_USERNAME=admin
LOGIN_PASSWORD=admin123

# REQUIRED: change to a long random string in production.
# Generate one with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string

# ── OAuth — Google (optional) ─────────────────────────────────────────────────
# Set up at: https://console.cloud.google.com/apis/credentials
# Authorised redirect URI: {NEXT_PUBLIC_BASE_URL}/api/auth/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Full public URL of your deployment (no trailing slash)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Can also be configured from the Settings page inside the app.
# Provider: "anthropic" | "openai"
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
LLM_API_KEY=sk-ant-api03-...

# ── RAG Parameters (optional — these are the defaults) ───────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K=3

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
